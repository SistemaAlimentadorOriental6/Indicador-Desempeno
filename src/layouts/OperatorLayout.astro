---
import "../styles/global.css";
import OperatorSidebar from "@components/layout/OperatorSidebar.astro";
import { ViewTransitions } from "astro:transitions";

interface Props {
    titulo: string;
}

const { titulo } = Astro.props;
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <title>{titulo} | SAO6</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap"
            rel="stylesheet"
        />
        <ViewTransitions />
    </head>
    <body>
        <div class="operator-container">
            <OperatorSidebar />

            <main class="main-content">
                <div class="content-wrapper">
                    <slot />
                </div>
            </main>
        </div>

        <style is:global>
            html,
            body {
                margin: 0;
                padding: 0;
                width: 100%;
                max-width: 100%;
                overflow-x: hidden; /* Prohibir el scroll horizontal a nivel global */
            }
        </style>

        <style>
            .operator-container {
                display: flex;
                min-height: 100vh;
                background-color: var(--color-fondo-app);
                width: 100%;
                max-width: 100vw;
                overflow: hidden;
            }

            .main-content {
                flex: 1;
                min-width: 0;
                padding: 40px;
                overflow-y: auto;
                height: 100vh;
                box-sizing: border-box;
                display: flex;
                flex-direction: column;
            }

            .content-wrapper {
                width: 100%;
                max-width: 1400px; /* Evita que el contenido se estire demasiado en pantallas gigantes */
                margin: 0 auto;
            }

            @media (max-width: 1200px) {
                .main-content {
                    padding: 30px;
                }
            }

            @media (max-width: 768px) {
                .operator-container {
                    flex-direction: column;
                    overflow-y: auto;
                }
                .main-content {
                    height: auto;
                    min-height: calc(100vh - 100px);
                    padding: 20px 15px;
                    overflow-y: visible;
                }
                .content-wrapper {
                    max-width: 100%;
                }
            }
        </style>
    </body>
</html>
