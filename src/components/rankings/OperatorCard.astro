---
import Icon from "../ui/Icon.astro";

interface Props {
    nombre: string;
    rango: string;
    eficiencia: string;
    efAnual: number;
    bonos: string;
    km: string;
    imagen: string;
    posicion: number;
    kmMeta?: string;
    bonosMeta?: string;
    kmProgreso: number;
    bonosProgreso: number;
    codigo: string;
}

const {
    nombre,
    rango,
    eficiencia,
    efAnual,
    bonos,
    km,
    imagen,
    posicion,
    kmProgreso,
    bonosProgreso,
    codigo,
} = Astro.props;
---

<div
    class="operator-card"
    data-nombre={nombre}
    data-rango={rango}
    data-eficiencia={eficiencia}
    data-imagen={imagen}
    data-codigo={codigo}
>
    <div class="rank-badge">#{posicion}</div>
    <div class="card-header">
        <div class="avatar-wrapper">
            <img src={imagen} alt={nombre} class="operator-img" />
            <div class={`status-tag ${rango.toLowerCase()}`}>
                <Icon name="medal" size={12} />
                {rango}
            </div>
        </div>
    </div>

    <div class="card-body">
        <h2 class="operator-name">
            {nombre}
            <Icon name="target" size={16} color="#46c93a" class="check-icon" />
        </h2>
        <p class="operator-role">OPERADOR</p>
        <p class="operator-zone">
            <Icon name="target" size={12} />
            Cód: {codigo}
        </p>

        <!-- Grid de métricas 2x2 -->
        <div class="metrics-grid">
            <div class="metric-card efficiency">
                <span class="metric-label">Eficiencia</span>
                <span class="metric-value">{eficiencia}</span>
            </div>

            <div class="metric-card annual">
                <span class="metric-label">Ef. Anual</span>
                <div class="metric-row">
                    <span class="metric-value">{efAnual}%</span>
                    <div class="progress-circle-mini">
                        <svg viewBox="0 0 36 36" class="circular-chart">
                            <path
                                class="circle-bg"
                                d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                            ></path>
                            <path
                                class="circle"
                                stroke-dasharray={`${efAnual}, 100`}
                                d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                            ></path>
                        </svg>
                    </div>
                </div>
            </div>

            <div class="metric-card">
                <span class="metric-label">Bonos</span>
                <span class="metric-value">{bonos}</span>
            </div>

            <div class="metric-card">
                <span class="metric-label">KM</span>
                <span class="metric-value">{km}</span>
            </div>
        </div>

        <!-- Barras de progreso inferiores -->
        <div class="progress-section">
            <div class="progress-header">
                <span class="label">Kilómetros</span>
                <span class="value">{kmProgreso}%</span>
            </div>
            <div class="progress-bar-container">
                <div
                    class="progress-bar km"
                    style={`width: ${Math.min(kmProgreso, 100)}%`}
                >
                </div>
            </div>

            <div class="progress-header">
                <span class="label">Bonos</span>
                <span class="value">{bonosProgreso}%</span>
            </div>
            <div class="progress-bar-container">
                <div
                    class="progress-bar bonos"
                    style={`width: ${Math.min(bonosProgreso, 100)}%`}
                >
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .operator-card {
        background: white;
        border-radius: 28px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        position: relative;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        border: 1px solid rgba(0, 0, 0, 0.03);
    }

    .operator-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    }

    .rank-badge {
        position: absolute;
        top: 20px;
        right: 20px;
        background: #4cc253;
        color: white;
        padding: 4px 10px;
        border-radius: 12px;
        font-weight: 800;
        font-size: 0.75rem;
        z-index: 10;
    }

    .avatar-wrapper {
        width: 100px;
        height: 100px;
        margin: 0 auto 15px;
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .operator-img {
        width: 100px;
        height: 100px;
        border-radius: 20px;
        object-fit: cover;
        border: 4px solid #f8f9fa;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
    }

    .status-tag {
        position: absolute;
        bottom: -5px;
        background: #012921;
        color: white;
        font-size: 0.65rem;
        font-weight: 800;
        padding: 4px 12px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        gap: 5px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
        z-index: 2;
    }

    .operator-name {
        text-align: center;
        font-size: 1rem;
        font-weight: 800;
        color: #012921;
        margin-top: 10px;
        margin-bottom: 5px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .operator-role {
        text-align: center;
        font-size: 0.75rem;
        font-weight: 600;
        color: #a0a6ae;
        text-transform: uppercase;
        margin-bottom: 5px;
    }

    .operator-zone {
        text-align: center;
        font-size: 0.7rem;
        color: #747d8c;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 4px;
        margin-bottom: 20px;
        background: #f1f2f6;
        padding: 4px 12px;
        border-radius: 20px;
        width: fit-content;
        margin-left: auto;
        margin-right: auto;
    }

    /* Grid de Métricas */
    .metrics-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 20px;
    }

    .metric-card {
        background: #f8f9fa;
        padding: 15px;
        border-radius: 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 5px;
    }

    .metric-card.efficiency {
        background: #f0fff4;
    }

    .metric-card.annual {
        background: #f0fff4;
    }

    .metric-row {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .metric-label {
        font-size: 0.8rem;
        font-weight: 600;
        color: #636e72;
    }

    .efficiency .metric-label,
    .annual .metric-label {
        color: #2ecc71;
    }

    .metric-value {
        font-size: 1.1rem;
        font-weight: 800;
        color: #2d3436;
    }

    .efficiency .metric-value {
        color: #27ae60;
    }

    /* Círculo de progreso mini */
    .progress-circle-mini {
        width: 24px;
        height: 24px;
    }

    .circular-chart {
        display: block;
        max-width: 100%;
        max-height: 100%;
    }

    .circle-bg {
        fill: none;
        stroke: #eee;
        stroke-width: 3.8;
    }

    .circle {
        fill: none;
        stroke: #2ecc71;
        stroke-width: 3.8;
        stroke-linecap: round;
        transition: stroke-dasharray 0.3s ease;
    }

    /* Sección de progreso */
    .progress-section {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .progress-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: -5px;
    }

    .progress-header .label {
        font-size: 0.85rem;
        font-weight: 700;
        color: #012921;
    }

    .progress-header .value {
        font-size: 0.85rem;
        font-weight: 800;
        color: #2ecc71;
    }

    .progress-bar-container {
        width: 100%;
        height: 8px;
        background: #f1f2f6;
        border-radius: 4px;
        overflow: hidden;
    }

    .progress-bar {
        height: 100%;
        border-radius: 4px;
        transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .progress-bar.km {
        background: #2ecc71;
    }

    .progress-bar.bonos {
        background: #55efc4;
    }
</style>
