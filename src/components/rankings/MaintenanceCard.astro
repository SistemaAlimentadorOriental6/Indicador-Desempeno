---
import Icon from "../ui/Icon.astro";

interface Props {
    nombre: string;
    rango: string;
    rangoLabel?: string;
    rol: string;
    imagen: string;
    posicion?: number;
    horasRealizadas: string | number;
    horasProgramadas: string | number;
    cumplimiento: string;
    cedula: string;
    detalleRealizado?: any[];
    detalleProgramado?: any[];
    // Nuevos campos
    codigo?: string;
    zona?: string;
    padrino?: string;
    ingreso?: string;
    edad?: string;
    antiguedad?: string;
}

const {
    nombre,
    rango, // ORO, PLATA, BRONCE
    rangoLabel = "Técnico",
    rol,
    imagen,
    posicion,
    horasRealizadas,
    horasProgramadas,
    cumplimiento,
    cedula,
    detalleRealizado = [],
    detalleProgramado = [],
    codigo = "---",
    zona = "---",
    padrino = "---",
    ingreso = "---",
    edad = "---",
    antiguedad = "---",
} = Astro.props;

// Determinar color basado en rango
const getColor = (r: string) => {
    switch (r) {
        case "ORO":
            return "#fbbf24";
        case "PLATA":
            return "#94a3b8";
        case "BRONCE":
            return "#b45309";
        default:
            return "#64748b";
    }
};

const badgeColor = getColor(rango);

// Parse cumplimiento number for chart
const cumplimientoNum = parseFloat(cumplimiento.replace("%", ""));
const chartColor =
    cumplimientoNum >= 95
        ? "#2ecc71"
        : cumplimientoNum >= 85
          ? "#f1c40f"
          : "#e74c3c";

// Función para convertir decimal a HH:mm
const formatHours = (decimal: any) => {
    const num = parseFloat(decimal || 0);
    if (isNaN(num)) return "0:00";
    const h = Math.floor(Math.abs(num));
    const m = Math.round((Math.abs(num) % 1) * 60);
    const sign = num < 0 ? "-" : "";
    return `${sign}${h}:${m.toString().padStart(2, "0")}`;
};
---

<div
    class="maintenance-card maintenance-card-trigger"
    data-nombre={nombre}
    data-cedula={cedula}
    data-rol={rol}
    data-rango={rango}
    data-imagen={imagen}
    data-horas-programadas={horasProgramadas}
    data-horas-realizadas={horasRealizadas}
    data-cumplimiento={cumplimiento}
    data-detalle-realizado={JSON.stringify(detalleRealizado)}
    data-detalle-programado={JSON.stringify(detalleProgramado)}
    data-codigo={codigo}
    data-zona={zona}
    data-padrino={padrino}
    data-ingreso={ingreso}
    data-edad={edad}
    data-antiguedad={antiguedad}
>
    {posicion && <div class="rank-badge">#{posicion}</div>}

    <div class="card-content-actual">
        <div class="card-header">
            <div class="avatar-wrapper">
                <img
                    src={imagen}
                    alt={nombre}
                    class="operator-img"
                    loading="lazy"
                    onerror="this.onerror=null; this.src='data:image/svg+xml;charset=UTF-8,%3Csvg xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22 viewBox%3D%220 0 24 24%22 fill%3D%22%23cbd5e1%22%3E%3Cpath d%3D%22M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z%22%2F%3E%3C%2Fsvg%3E'; this.parentElement.classList.add('is-error');"
                />
                <div
                    class="status-tag"
                    style={`background-color: ${badgeColor}`}
                >
                    <Icon name="medal" size={12} />
                    {rango}
                </div>
            </div>
        </div>

        <div class="card-body">
            <h2 class="operator-name">
                {nombre}
            </h2>
            <p class="operator-role">{rol}</p>
            <p class="operator-id">ID: {cedula}</p>

            <div class="metrics-container">
                <div class="main-metric">
                    <span class="label">Cumplimiento</span>
                    <div class="value-row">
                        <span class="value" style={`color: ${chartColor}`}
                            >{cumplimiento}</span
                        >
                        <div class="mini-chart">
                            <svg viewBox="0 0 36 36" class="circular-chart">
                                <path
                                    class="circle-bg"
                                    d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                                ></path>
                                <path
                                    class="circle"
                                    stroke-dasharray={`${cumplimientoNum}, 100`}
                                    stroke={chartColor}
                                    d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                                ></path>
                            </svg>
                        </div>
                    </div>
                </div>

                <div class="secondary-metrics">
                    <div class="metric-box">
                        <span class="label">H. Programadas</span>
                        <span class="value"
                            >{formatHours(horasProgramadas)}</span
                        >
                    </div>
                    <div class="metric-box">
                        <span class="label">H. Realizadas</span>
                        <span class="value">{formatHours(horasRealizadas)}</span
                        >
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .maintenance-card {
        background: white;
        border-radius: 24px;
        padding: 20px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
        position: relative;
        border: 1px solid #f1f5f9;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        overflow: hidden;
        min-height: 380px;
        display: flex;
        flex-direction: column;
        animation: slideUpFade 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    @keyframes slideUpFade {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .maintenance-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
        border-color: #2ecc71; /* Color primario suave */
    }

    .rank-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        background: #0f172a;
        color: white;
        padding: 4px 12px;
        border-radius: 12px;
        font-weight: 800;
        font-size: 0.8rem;
        z-index: 10;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
    }

    .avatar-wrapper {
        display: flex;
        justify-content: center;
        margin-bottom: 20px;
        position: relative;
        width: 100px;
        height: 100px;
        margin-left: auto;
        margin-right: auto;
    }

    .operator-img {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid white;
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
        transition: transform 0.3s ease;
    }

    .maintenance-card:hover .operator-img {
        transform: scale(1.05);
    }

    .status-tag {
        position: absolute;
        bottom: -5px;
        color: white;
        font-size: 0.7rem;
        font-weight: 800;
        padding: 4px 12px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        gap: 6px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
        white-space: nowrap;
    }

    .operator-name {
        font-size: 1.1rem;
        font-weight: 800;
        text-align: center;
        color: #0f172a;
        margin-bottom: 5px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        letter-spacing: -0.02em;
    }

    .operator-role {
        text-align: center;
        font-size: 0.85rem;
        color: #64748b;
        font-weight: 600;
        margin-bottom: 4px;
    }

    .operator-id {
        text-align: center;
        font-size: 0.75rem;
        color: #94a3b8;
        margin-bottom: 20px;
    }

    .metrics-container {
        display: flex;
        flex-direction: column;
        gap: 15px;
        margin-top: auto;
    }

    .main-metric {
        background: #f8fafc;
        padding: 15px;
        border-radius: 20px;
        text-align: center;
        transition: background 0.3s ease;
    }

    .maintenance-card:hover .main-metric {
        background: #f1f5f9;
    }

    .main-metric .label {
        display: block;
        font-size: 0.75rem;
        color: #64748b;
        font-weight: 800;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .value-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
    }

    .main-metric .value {
        font-size: 1.6rem;
        font-weight: 950;
        letter-spacing: -0.03em;
    }

    .mini-chart {
        width: 35px;
        height: 35px;
    }

    .circular-chart {
        display: block;
        max-width: 100%;
        max-height: 100%;
    }

    .circle-bg {
        fill: none;
        stroke: #e2e8f0;
        stroke-width: 4;
    }

    .circle {
        fill: none;
        stroke-width: 4;
        stroke-linecap: round;
        transition: stroke-dasharray 1s ease-in-out;
    }

    .secondary-metrics {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .metric-box {
        background: #ffffff;
        border: 1px solid #f1f5f9;
        padding: 12px;
        border-radius: 16px;
        text-align: center;
        transition: all 0.3s ease;
    }

    .maintenance-card:hover .metric-box {
        border-color: #e2e8f0;
        transform: translateY(-2px);
    }

    .metric-box .label {
        display: block;
        font-size: 0.65rem;
        color: #94a3b8;
        font-weight: 800;
        margin-bottom: 4px;
        text-transform: uppercase;
    }

    .metric-box .value {
        font-size: 1rem;
        font-weight: 900;
        color: #1e293b;
    }
</style>
