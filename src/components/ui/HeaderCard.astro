---
interface Props {
    titulo: string;
    subtitulo: string;
}

const { titulo, subtitulo } = Astro.props;
---

<div class="header-card">
    <div class="header-icon">
        <slot name="icon">
            <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path>
                <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path>
                <path d="M4 22h16"></path>
                <path d="M10 14.66V20"></path>
                <path d="M14 14.66V20"></path>
                <path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path>
            </svg>
        </slot>
    </div>
    <div class="header-text">
        <h1>{titulo}</h1>
        <p>{subtitulo}</p>
    </div>
    
    <!-- Contenedor para indicadores de bono perfecto, inyectado via JS -->
    <div id="bono-perfecto-stats" class="bono-perfecto-stats hidden">
        <div class="bp-title">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg>
            Operadores con 100% Bono
            <span class="bp-ver-grafico">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="12" width="4" height="9"/><rect x="10" y="7" width="4" height="14"/><rect x="17" y="3" width="4" height="18"/></svg>
                Ver gráfico
            </span>
        </div>
        <div class="bp-badges">
            <div class="bp-badge bp-oro" title="Oro con bono 100%">
                <span class="bp-dot"></span>
                Oro: <strong id="bp-count-oro">0</strong>
            </div>
            <div class="bp-badge bp-plata" title="Plata con bono 100%">
                <span class="bp-dot"></span>
                Plata: <strong id="bp-count-plata">0</strong>
            </div>
            <div class="bp-badge bp-bronce" title="Bronce con bono 100%">
                <span class="bp-dot"></span>
                Bronce: <strong id="bp-count-bronce">0</strong>
            </div>
            <div class="bp-badge bp-mejorar" title="Mejorar con bono 100%">
                <span class="bp-dot"></span>
                Mejorar: <strong id="bp-count-mejorar">0</strong>
            </div>
            <div class="bp-badge bp-taller" title="Taller Conciencia con bono 100%">
                <span class="bp-dot"></span>
                Taller: <strong id="bp-count-taller">0</strong>
            </div>
            <div class="bp-badge bp-total" title="Total con bono 100%">
                <span id="bp-count-total">0</span> Totales
            </div>
        </div>
    </div>
</div>

<style>
    .header-card {
        background: white;
        padding: 25px;
        border-radius: var(--radio-lg);
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 25px;
        box-shadow: var(--sombra-suave);
    }

    .header-icon {
        width: 50px;
        height: 50px;
        background: var(--color-primario);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }

    .header-icon :global(svg) {
        width: 28px;
        height: 28px;
    }

    .header-text {
        flex: 1;
    }

    .header-text h1 {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--color-texto-dark);
    }

    .header-text p {
        color: var(--color-texto-grey);
        font-size: 0.9rem;
    }
    
    /* Estilos para Bono Perfecto Stats */
    .bono-perfecto-stats {
        background: #ffffff;
        border: 1.5px solid #f1f5f9;
        border-radius: var(--radio-lg);
        padding: 16px 24px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-left: auto;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
    }

    .bono-perfecto-stats:hover {
        transform: translateY(-3px) scale(1.01);
        box-shadow: 0 12px 28px -8px rgba(76, 194, 83, 0.2), 0 0 0 2px var(--color-primario);
        border-color: var(--color-primario);
    }

    .bono-perfecto-stats:hover .bp-title svg {
        animation: bounceIcon 0.5s ease;
    }

    @keyframes bounceIcon {
        0%, 100% { transform: scale(1); }
        40%       { transform: scale(1.3) rotate(-10deg); }
        70%       { transform: scale(0.9) rotate(5deg); }
    }

    /* Texto "Ver gráfico" */
    .bp-ver-grafico {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--color-primario);
        background: var(--color-primario-soft);
        padding: 3px 9px;
        border-radius: 20px;
        margin-left: 6px;
        opacity: 0;
        transform: translateX(-4px);
        transition: all 0.2s ease;
    }

    .bono-perfecto-stats:hover .bp-ver-grafico {
        opacity: 1;
        transform: translateX(0);
    }

    .bono-perfecto-stats.hidden {
        display: none !important;
    }
    
    .bp-title {
        font-size: 0.9rem;
        font-weight: 800;
        color: #1e293b;
        display: flex;
        align-items: center;
        gap: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin: 0;
    }
    
    .bp-title svg {
        color: var(--color-primario);
    }
    
    .bp-badges {
        display: flex;
        flex-direction: row;
        gap: 8px;
        align-items: center;
    }
    
    .bp-badge {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 500;
        background: white;
        white-space: nowrap;
        margin: 0;
        color: #475569;
        transition: transform 0.2s ease;
    }

    .bp-badge:hover {
        transform: translateY(-2px);
    }

    .bp-badge strong {
        font-weight: 800;
        font-size: 0.95rem;
    }
    
    .bp-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }
    
    .bp-oro { border: 1.5px solid #fef08a; background: #fefce8; }
    .bp-oro .bp-dot { background: #eab308; box-shadow: 0 0 6px rgba(234, 179, 8, 0.5); }
    .bp-oro strong { color: #ca8a04; }
    
    .bp-plata { border: 1.5px solid #e2e8f0; background: #f8fafc; }
    .bp-plata .bp-dot { background: #94a3b8; box-shadow: 0 0 6px rgba(148, 163, 184, 0.5); }
    .bp-plata strong { color: #64748b; }
    
    .bp-bronce { border: 1.5px solid #fed7aa; background: #fff7ed; }
    .bp-bronce .bp-dot { background: #f97316; box-shadow: 0 0 6px rgba(249, 115, 22, 0.5); }
    .bp-bronce strong { color: #c2410c; }
    
    .bp-mejorar { border: 1.5px solid #fed7aa; background: #fff7ed; }
    .bp-mejorar .bp-dot { background: #ea580c; box-shadow: 0 0 6px rgba(234, 88, 12, 0.5); }
    .bp-mejorar strong { color: #c2410c; }

    .bp-taller { border: 1.5px solid #fecaca; background: #fef2f2; }
    .bp-taller .bp-dot { background: #ef4444; box-shadow: 0 0 6px rgba(239, 68, 68, 0.5); }
    .bp-taller strong { color: #b91c1c; }
    
    .bp-total { 
        background: var(--color-primario); 
        color: white; 
        border: none;
        padding: 6px 16px;
        box-shadow: 0 4px 10px rgba(34, 197, 94, 0.2);
    }
    .bp-total span {
        font-weight: 800;
        font-size: 1.05rem;
    }
</style>
