---
---

<div id="modal-bono-chart" class="bono-modal-overlay">
    <div class="bono-modal-content">

        <!-- Header del Modal -->
        <div class="bono-modal-header">
            <div class="bono-modal-header-left">
                <div class="bono-modal-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="8" r="7"></circle>
                        <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
                    </svg>
                </div>
                <div>
                    <h2>Operadores con 100% Bono</h2>
                    <div class="bono-modal-subtitle-wrapper">
                        <p id="bono-modal-subtitle">Distribución por rango</p>
                        
                        <div class="custom-period-selector" id="bono-period-selector">
                            <button class="period-selector-btn" id="period-selector-btn">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="bono-month-icon"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                                <span id="period-selector-text">Mes - Año</span>
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="period-chevron"><polyline points="6 9 12 15 18 9"></polyline></svg>
                            </button>
                            <div class="period-selector-dropdown" id="period-selector-dropdown">
                                <div class="period-year-nav">
                                    <button class="period-year-btn" id="period-prev-year">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
                                    </button>
                                    <span id="period-current-year">2026</span>
                                    <button class="period-year-btn" id="period-next-year">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                                    </button>
                                </div>
                                <div class="period-months-grid" id="period-months-grid">
                                    <button class="period-month-btn" data-month="0">Ene</button>
                                    <button class="period-month-btn" data-month="1">Feb</button>
                                    <button class="period-month-btn" data-month="2">Mar</button>
                                    <button class="period-month-btn" data-month="3">Abr</button>
                                    <button class="period-month-btn" data-month="4">May</button>
                                    <button class="period-month-btn" data-month="5">Jun</button>
                                    <button class="period-month-btn" data-month="6">Jul</button>
                                    <button class="period-month-btn" data-month="7">Ago</button>
                                    <button class="period-month-btn" data-month="8">Sep</button>
                                    <button class="period-month-btn" data-month="9">Oct</button>
                                    <button class="period-month-btn" data-month="10">Nov</button>
                                    <button class="period-month-btn" data-month="11">Dic</button>
                                </div>
                                <div class="period-selector-footer">
                                    <button class="period-all-btn" id="period-all-btn">Ver todos los periodos</button>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
            <button class="bono-modal-close" id="bono-modal-close-btn" aria-label="Cerrar">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>

        <!-- Cuerpo -->
        <div class="bono-modal-body">

            <!-- Panel izquierdo -->
            <div class="bono-modal-sidebar">
                <div class="bono-sidebar-top">
                    <!-- Círculo principal -->
                    <div class="bono-total-wrapper">
                        <div class="bono-total-circle">
                            <span class="bono-total-number" id="bono-modal-total">0</span>
                            <span class="bono-total-label">operadores</span>
                        </div>
                        <p class="bono-total-desc">con cumplimiento<br><strong>100% de bono</strong></p>
                    </div>

                    <!-- Porcentaje Global -->
                    <div class="bono-global-card" id="bono-modal-global-pct">
                        <!-- Llenado por JS -->
                    </div>
                </div>

                <div class="bono-sidebar-bottom">
                    <div class="bono-mini-badges" id="bono-mini-badges">
                        <!-- Llenado por JS -->
                    </div>
                </div>
            </div>

            <!-- Área del gráfico -->
            <div class="bono-modal-chart-area">
                <div class="bono-chart-header">
                    <div class="bono-chart-toggle">
                        <button class="bono-toggle-btn active" data-type="bar" id="toggle-bar">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><rect x="3" y="12" width="4" height="9"/><rect x="10" y="7" width="4" height="14"/><rect x="17" y="3" width="4" height="18"/></svg>
                            Barras
                        </button>
                        <button class="bono-toggle-btn" data-type="doughnut" id="toggle-doughnut">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/></svg>
                            Dona
                        </button>
                    </div>
                </div>
                <div class="bono-canvas-wrapper">
                    <canvas id="bono-modal-chart"></canvas>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    import Chart from "chart.js/auto";
    import { FiltroService } from "@services/FiltroService";

    const COLORES: Record<string, { bg: string; border: string; soft: string }> = {
        Oro:     { bg: "#d97706", border: "#b45309", soft: "#fef3c7" },
        Plata:   { bg: "#475569", border: "#334155", soft: "#f1f5f9" },
        Bronce:  { bg: "#ea580c", border: "#c2410c", soft: "#ffedd5" },
        Mejorar: { bg: "#ea580c", border: "#9a3412", soft: "#fff7ed" },
        "Taller Conciencia": { bg: "#8b5cf6", border: "#6d28d9", soft: "#ede9fe" },
    };

    let modalChart: Chart | null = null;
    let tipoGrafico: "bar" | "doughnut" = "bar";
    let datosActuales: Record<string, number> = {};
    let totalColaboradoresGlobal: number = 0;

    const overlay  = document.getElementById("modal-bono-chart");
    const closeBtn = document.getElementById("bono-modal-close-btn");

    const selectorBtn = document.getElementById("period-selector-btn");
    const dropdown = document.getElementById("period-selector-dropdown");
    const textSpan = document.getElementById("period-selector-text");
    const prevYearBtn = document.getElementById("period-prev-year");
    const nextYearBtn = document.getElementById("period-next-year");
    const yearSpan = document.getElementById("period-current-year");
    const monthBtns = document.querySelectorAll(".period-month-btn");
    const allBtn = document.getElementById("period-all-btn");
    
    let selectedYear = new Date().getFullYear();
    let selectedMonth = -1; // -1 means 'all' or year-only depending on context
    const shortMonthNames = ["Ene", "Feb", "Mar", "Abr", "May", "Jun", "Jul", "Ago", "Sep", "Oct", "Nov", "Dic"];

    const cerrarModal = () => {
        overlay?.classList.remove("open");
        document.body.style.overflow = "auto";
        if (modalChart) { modalChart.destroy(); modalChart = null; }
        dropdown?.classList.remove("open");
    };

    closeBtn?.addEventListener("click", cerrarModal);
    overlay?.addEventListener("click", (e) => { if (e.target === overlay) cerrarModal(); });
    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && overlay?.classList.contains("open")) cerrarModal();
    });

    selectorBtn?.addEventListener("click", (e) => {
        e.stopPropagation();
        dropdown?.classList.toggle("open");
    });

    document.addEventListener("click", (e) => {
        if (dropdown && dropdown.classList.contains("open") && !document.getElementById("bono-period-selector")?.contains(e.target as Node)) {
            dropdown.classList.remove("open");
        }
    });

    const updateSelectorUI = () => {
        if (yearSpan) yearSpan.textContent = selectedYear.toString();
        
        monthBtns.forEach(btn => {
            const m = parseInt((btn as HTMLElement).dataset.month || "0", 10);
            if (m === selectedMonth) {
                btn.classList.add("active");
            } else {
                btn.classList.remove("active");
            }
        });

        if (selectedMonth >= 0) {
            if (textSpan) textSpan.textContent = `${shortMonthNames[selectedMonth]} ${selectedYear}`;
        } else {
            if (textSpan) textSpan.textContent = "Todos los periodos";
        }
    };

    const applyPeriodFilter = () => {
        const currentFilters = FiltroService.obtenerDeUrl();
        if (selectedMonth >= 0) {
            currentFilters.periodo = { tipo: "month", anio: selectedYear, mes: selectedMonth };
        } else {
            currentFilters.periodo = { tipo: "all", anio: selectedYear, mes: -1 };
        }
        
        document.dispatchEvent(new CustomEvent("applyFilters", { detail: currentFilters }));
        FiltroService.sincronizarUrl(currentFilters);
        dropdown?.classList.remove("open");
    };

    prevYearBtn?.addEventListener("click", (e) => {
        e.stopPropagation();
        selectedYear--;
        updateSelectorUI();
    });

    nextYearBtn?.addEventListener("click", (e) => {
        e.stopPropagation();
        selectedYear++;
        updateSelectorUI();
    });

    monthBtns.forEach(btn => {
        btn.addEventListener("click", (e) => {
            e.stopPropagation();
            selectedMonth = parseInt((btn as HTMLElement).dataset.month || "0", 10);
            updateSelectorUI();
            applyPeriodFilter();
        });
    });

    allBtn?.addEventListener("click", (e) => {
        e.stopPropagation();
        selectedMonth = -1;
        updateSelectorUI();
        applyPeriodFilter();
    });

    // Toggle tipo de gráfico
    document.querySelectorAll(".bono-toggle-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
            document.querySelectorAll(".bono-toggle-btn").forEach(b => b.classList.remove("active"));
            btn.classList.add("active");
            tipoGrafico = (btn as HTMLElement).dataset.type as "bar" | "doughnut";
            renderizarGrafico(datosActuales);
        });
    });

    function renderizarGrafico(porRango: Record<string, number>) {
        const ctx = document.getElementById("bono-modal-chart") as HTMLCanvasElement;
        if (!ctx) return;

        if (modalChart) { modalChart.destroy(); modalChart = null; }

        const labels      = Object.keys(porRango);
        const valores     = Object.values(porRango);
        const backgrounds = labels.map(l => COLORES[l]?.bg || "#ccc");
        const borders     = labels.map(l => COLORES[l]?.border || "#999");
        const esDonut     = tipoGrafico === "doughnut";
        const total       = valores.reduce((a, b) => a + b, 0);

        // Plugin: etiquetas flotantes tipo "callout" encima de cada barra
        const pluginEtiquetas = {
            id: "etiquetasPersonalizadas",
            afterDatasetsDraw(chart: any) {
                if (esDonut) return;
                const { ctx: c, data } = chart;
                const dataset = data.datasets[0];
                const meta    = chart.getDatasetMeta(0);

                meta.data.forEach((bar: any, i: number) => {
                    const valor = dataset.data[i] as number;
                    if (valor === 0) return;
                    const pct  = totalColaboradoresGlobal > 0 ? Math.round((valor / totalColaboradoresGlobal) * 100) : 0;
                    const x    = bar.x;
                    const yTop = bar.y;

                    c.save();

                    // Pill de fondo
                    const pillW = 64, pillH = 50;
                    const pillX = x - pillW / 2;
                    const pillY = yTop - pillH - 14;

                    c.beginPath();
                    c.roundRect(pillX, pillY, pillW, pillH, 8);
                    c.fillStyle    = "rgba(255,255,255,1)";
                    c.shadowColor  = "rgba(0,0,0,0.15)";
                    c.shadowBlur   = 10;
                    c.shadowOffsetY = 4;
                    c.fill();
                    c.shadowBlur = 0;

                    c.strokeStyle = COLORES[labels[i]]?.border + "66" || "#e2e8f0";
                    c.lineWidth   = 1;
                    c.stroke();

                    // Triangulito de puntero (callout)
                    c.beginPath();
                    c.moveTo(x - 7, pillY + pillH);
                    c.lineTo(x + 7, pillY + pillH);
                    c.lineTo(x,     pillY + pillH + 7);
                    c.closePath();
                    c.fillStyle   = "rgba(255,255,255,1)";
                    c.fill();

                    // Número
                    c.fillStyle    = "#0f172a";
                    c.font         = "900 16px 'Outfit', sans-serif";
                    c.textAlign    = "center";
                    c.textBaseline = "top";
                    c.fillText(String(valor), x, pillY + 8);

                    // Porcentaje
                    c.font      = "700 12px 'Outfit', sans-serif";
                    c.fillStyle = COLORES[labels[i]]?.bg || "#64748b";
                    c.fillText(`${pct}%`, x, pillY + 28);

                    c.restore();
                });
            }
        };

        modalChart = new Chart(ctx, {
            type: tipoGrafico,
            plugins: esDonut ? [] : [pluginEtiquetas],
            data: {
                labels,
                datasets: [{
                    label: "Operadores",
                    data: valores,
                    backgroundColor: backgrounds,
                    borderColor: esDonut ? "#ffffff" : "transparent",
                    borderWidth: esDonut ? 3 : 0,
                    borderRadius: esDonut ? 0 : { topLeft: 16, topRight: 16, bottomLeft: 4, bottomRight: 4 },
                    barThickness: esDonut ? undefined : 64,
                    hoverBackgroundColor: backgrounds,
                    ...(esDonut ? { hoverOffset: 14 } : {}),
                }]
            },
            options: {
                onClick: (e: any, elements: any[]) => {
                    if (elements.length > 0) {
                        const index = elements[0].index;
                        const clickedRango = modalChart?.data.labels?.[index] as string;
                        if (clickedRango) {
                            cerrarModal();
                            document.dispatchEvent(new CustomEvent('filterByBonoPerfecto', { detail: clickedRango }));
                        }
                    }
                },
                onHover: (e: any, elements: any[]) => {
                    const canvas = e.native?.target;
                    if (canvas) {
                        canvas.style.cursor = elements && elements.length > 0 ? 'pointer' : 'default';
                    }
                },
                responsive: true,
                maintainAspectRatio: false,
                layout: { padding: { top: 80, bottom: 20 } },
                cutout: esDonut ? "65%" : undefined,
                plugins: {
                    legend: {
                        display: esDonut,
                        position: "right",
                        labels: {
                            usePointStyle: true,
                            padding: 22,
                            font: { family: "'Outfit', sans-serif", size: 14, weight: "600" },
                            color: "#1e293b",
                        }
                    },
                    tooltip: {
                        backgroundColor: "rgba(255,255,255,0.98)",
                        titleColor: "#0f172a",
                        bodyColor: "#475569",
                        borderColor: "#e2e8f0",
                        borderWidth: 1,
                        padding: 16,
                        cornerRadius: 12,
                        titleFont: { family: "'Outfit', sans-serif", size: 14, weight: "bold" },
                        bodyFont: { family: "'Outfit', sans-serif", size: 13 },
                        callbacks: {
                            label: (c: any) => {
                                const v   = c.parsed.y ?? c.parsed;
                                const pct = totalColaboradoresGlobal > 0 ? Math.round((v / totalColaboradoresGlobal) * 100) : 0;
                                return ` ${v} operadores (${pct}% del total)`;
                            }
                        }
                    }
                },
                scales: esDonut
                    ? { x: { display: false }, y: { display: false } }
                    : {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                color: "#cbd5e1",
                                font: { family: "'Outfit', sans-serif", size: 12 }
                            },
                            grid: { color: "#f8fafc" },
                            border: { display: false }
                        },
                        x: {
                            grid: { display: false },
                            border: { display: false },
                            ticks: {
                                color: "#475569",
                                font: { family: "'Outfit', sans-serif", size: 14, weight: "bold" },
                                padding: 12
                            }
                        }
                    },
                animation: { duration: 800, easing: "easeOutQuart" }
            }
        } as any);
    }

    function actualizarBadges(porRango: Record<string, number>) {
        const container = document.getElementById("bono-mini-badges");
        if (!container) return;
        container.innerHTML = Object.entries(porRango).map(([rango, count]) => {
            const col = COLORES[rango] || COLORES["Plata"];
            const isEmpty = count === 0;
            return `
                <div class="bono-list-item clickable-rango ${isEmpty ? 'empty' : ''}" data-rango="${rango}" style="--item-color: ${col.bg};">
                    <div class="bono-list-left">
                        <span class="bono-list-dot" style="background: ${col.bg};"></span>
                        <span class="bono-list-label">${rango}</span>
                    </div>
                    <strong class="bono-list-count" style="color: ${isEmpty ? '#94a3b8' : col.border};">${count}</strong>
                </div>
            `;
        }).join("");

        container.querySelectorAll('.clickable-rango:not(.empty)').forEach(el => {
            el.addEventListener('click', (e) => {
                const rango = (e.currentTarget as HTMLElement).dataset.rango;
                if (rango) {
                    cerrarModal();
                    document.dispatchEvent(new CustomEvent('filterByBonoPerfecto', { detail: rango }));
                }
            });
        });
    }

    document.addEventListener("abrirBonoModal", (e: any) => {
        const { porRango, total, periodo, totalColaboradores, totalRegistrados } = e.detail;
        datosActuales = porRango;
        totalColaboradoresGlobal = totalColaboradores || 0;
        const registradosTotales = totalRegistrados || totalColaboradoresGlobal;

        const totalEl = document.getElementById("bono-modal-total");
        if (totalEl) totalEl.textContent = total.toString();

        const globalPctEl = document.getElementById("bono-modal-global-pct");
        if (globalPctEl) {
            const globalPct = totalColaboradoresGlobal > 0 ? Math.round((total / totalColaboradoresGlobal) * 100) : 0;
            globalPctEl.innerHTML = `
                <div class="bono-global-pct">${globalPct}%</div>
                <div class="bono-global-text">
                    Representa el <strong>${globalPct}%</strong> de<br>
                    los <strong>${registradosTotales}</strong> registrados
                </div>
            `;
        }

        const subtituloEl = document.getElementById("bono-modal-subtitle");
        if (subtituloEl && periodo) subtituloEl.textContent = `Distribución por rango — ${periodo}`;

        // Sincronizar el valor del input de mes/año con los filtros actuales
        const currentFilters = FiltroService.obtenerDeUrl();
        if (currentFilters.periodo) {
            if (currentFilters.periodo.tipo === "month") {
                selectedYear = currentFilters.periodo.anio;
                selectedMonth = currentFilters.periodo.mes;
                updateSelectorUI();
            } else if (currentFilters.periodo.tipo === "year") {
                selectedYear = currentFilters.periodo.anio;
                selectedMonth = -1;
                updateSelectorUI();
                if (textSpan) textSpan.textContent = `Año ${selectedYear}`;
            } else {
                selectedYear = new Date().getFullYear();
                selectedMonth = -1;
                updateSelectorUI();
            }
        }

        actualizarBadges(porRango);
        overlay?.classList.add("open");
        document.body.style.overflow = "hidden";
        setTimeout(() => renderizarGrafico(porRango), 50);
    });
</script>

<style is:global>
    /* =============================================
       MODAL OVERLAY
    ============================================= */
    .bono-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        z-index: 2000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.3s ease, visibility 0.3s ease;
    }

    .bono-modal-overlay.open {
        opacity: 1;
        visibility: visible;
    }

    /* =============================================
       MODAL CARD
    ============================================= */
    .bono-modal-content {
        background: #ffffff;
        border-radius: 24px;
        width: 100%;
        max-width: 900px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        overflow: hidden;
        transform: scale(0.95) translateY(10px);
        opacity: 0;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
        display: flex;
        flex-direction: column;
    }

    .bono-modal-overlay.open .bono-modal-content {
        transform: scale(1) translateY(0);
        opacity: 1;
    }

    /* =============================================
       HEADER
    ============================================= */
    .bono-modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 20px 28px;
        background: #ffffff;
        border-bottom: 1px solid #f1f5f9;
    }

    .bono-modal-header-left {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .bono-modal-icon {
        width: 48px;
        height: 48px;
        background: #22c55e;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        box-shadow: 0 8px 16px rgba(34, 197, 94, 0.3);
    }

    .bono-modal-header h2 {
        font-size: 1.3rem;
        font-weight: 800;
        color: #0f172a;
        margin: 0 0 2px 0;
        font-family: 'Outfit', sans-serif;
    }

    .bono-modal-header p {
        font-size: 0.85rem;
        color: #64748b;
        margin: 0;
        font-family: 'Outfit', sans-serif;
        font-weight: 500;
    }

    .bono-modal-subtitle-wrapper {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .custom-period-selector {
        position: relative;
        font-family: 'Outfit', sans-serif;
    }

    .period-selector-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 6px 12px;
        font-size: 0.8rem;
        font-weight: 600;
        color: #475569;
        cursor: pointer;
        transition: all 0.2s ease;
        height: 32px;
    }

    .period-selector-btn:hover {
        background: #f1f5f9;
        border-color: #cbd5e1;
        color: #0f172a;
    }

    .bono-month-icon {
        color: #64748b;
    }

    .period-chevron {
        color: #94a3b8;
        transition: transform 0.2s ease;
    }

    .period-selector-dropdown.open ~ .period-selector-btn .period-chevron {
        transform: rotate(180deg);
    }

    .custom-period-selector.open .period-chevron {
        transform: rotate(180deg);
    }

    .period-selector-dropdown {
        position: absolute;
        top: calc(100% + 8px);
        left: 0;
        width: 240px;
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
        border: 1px solid #e2e8f0;
        padding: 16px;
        z-index: 2000;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-10px);
        transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .period-selector-dropdown.open {
        opacity: 1;
        visibility: visible;
