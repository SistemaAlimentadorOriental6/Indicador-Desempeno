---
import ModalFiltros from "./ModalFiltros.astro";

interface Props {
    resultados: number;
}

const { resultados } = Astro.props;
---

<div class="search-section">
    <div class="search-card">
        <div class="search-header">
            <div class="search-icon-container">
                <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
            </div>
            <div class="search-info">
                <h3>Búsqueda</h3>
                <p>{resultados} resultados</p>
            </div>
            <div class="search-actions">
                <button class="icon-btn">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        ><line x1="8" y1="6" x2="21" y2="6"></line><line
                            x1="8"
                            y1="12"
                            x2="21"
                            y2="12"></line><line x1="8" y1="18" x2="21" y2="18"
                        ></line><line x1="3" y1="6" x2="3.01" y2="6"
                        ></line><line x1="3" y1="12" x2="3.01" y2="12"
                        ></line><line x1="3" y1="18" x2="3.01" y2="18"
                        ></line></svg
                    >
                </button>
                <button class="icon-btn">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        ><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
                        ></path><polyline points="7 10 12 15 17 10"
                        ></polyline><line x1="12" y1="15" x2="12" y2="3"
                        ></line></svg
                    >
                </button>
            </div>
        </div>

        <div class="input-group">
            <div class="input-wrapper">
                <svg
                    class="input-icon"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    ><circle cx="11" cy="11" r="8"></circle><line
                        x1="21"
                        y1="21"
                        x2="16.65"
                        y2="16.65"></line></svg
                >
                <input
                    type="text"
                    placeholder="Buscar por nombre, cédula o código..."
                    class="input-premium"
                />
            </div>
        </div>

        <div class="search-filters" id="active-filters-list">
            <span class="filter-label">Filtros:</span>
            <!-- Los chips se generarán dinámicamente -->
        </div>

        <button class="config-btn" id="open-filters-btn">
            <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><circle cx="12" cy="12" r="3"></circle><path
                    d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33 1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"
                ></path></svg
            >
            Configurar Filtros
            <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><polyline points="6 9 12 15 18 9"></polyline></svg
            >
        </button>
    </div>
</div>

<ModalFiltros />

<script>
    import { FiltroService, type FiltrosData } from "@services/FiltroService";

    const updateActiveFilterChips = (filtros: FiltrosData) => {
        const container = document.getElementById("active-filters-list");
        if (!container) return;

        // Limpiar excepto la etiqueta
        const label = container.querySelector(".filter-label");
        container.innerHTML = "";
        if (label) container.appendChild(label);

        const createChip = (text: string, iconSvg: string) => {
            const btn = document.createElement("button");
            btn.className = "filter-mini-btn";
            btn.innerHTML = `${iconSvg} ${text}`;
            return btn;
        };

        // 1. Chip de Pestaña (Categoría)
        if (filtros.pestana) {
            container.appendChild(
                createChip(
                    filtros.pestana,
                    `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>`,
                ),
            );
        }

        // 2. Chip de Estado (Actividad)
        const estadoLabels: Record<string, string> = {
            all: "Todos",
            active: "Activos",
            inactive: "Inactivos",
            novelty: "Con Novedad",
        };
        if (filtros.estado) {
            container.appendChild(
                createChip(
                    estadoLabels[filtros.estado] || filtros.estado,
                    `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="3" x2="9" y2="21"></line></svg>`,
                ),
            );
        }

        // 2.5 Chip de Cargo
        if (filtros.cargo && filtros.cargo !== "all") {
            container.appendChild(
                createChip(
                    filtros.cargo,
                    `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>`,
                ),
            );
        }

        // 3. Chip de Ordenamiento
        const sortLabels: Record<string, string> = {
            ranking: "Ranking",
            bonos: "Bonos",
            km: "Kilómetros",
            eficiencia: "Eficiencia",
        };
        const dirIcon =
            filtros.direccion === "asc"
                ? `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="19" x2="12" y2="5"></line><polyline points="5 12 12 5 19 12"></polyline></svg>`
                : `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><polyline points="19 12 12 19 5 12"></polyline></svg>`;

        if (filtros.ordenar) {
            const label = sortLabels[filtros.ordenar] || filtros.ordenar;
            const dirLabel = filtros.direccion === "asc" ? "↑" : "↓";
            container.appendChild(createChip(`${label} ${dirLabel}`, dirIcon));
        }

        // 4. Chip de Periodo
        if (filtros.periodo && filtros.periodo.tipo !== "all") {
            let pLabel = filtros.periodo.anio.toString();
            if (
                filtros.periodo.tipo === "month" &&
                filtros.periodo.mes !== -1
            ) {
                const meses = [
                    "Ene",
                    "Feb",
                    "Mar",
                    "Abr",
                    "May",
                    "Jun",
                    "Jul",
                    "Ago",
                    "Sep",
                    "Oct",
                    "Nov",
                    "Dic",
                ];
                pLabel = `${meses[filtros.periodo.mes]} ${pLabel}`;
            }
            container.appendChild(
                createChip(
                    pLabel,
                    `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>`,
                ),
            );
        }
        
        // 5. Chip de Bono Perfecto (Deseleccionable)
        if (filtros.bono100Rango) {
            const btn = document.createElement("button");
            btn.className = "filter-mini-btn";
            btn.style.borderColor = "#4cc253";
            btn.style.backgroundColor = "#f0fdf4";
            btn.style.color = "#166534";
            btn.title = "Clic para quitar filtro";
            btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg> 
                100% Bono: ${filtros.bono100Rango} 
                <span style="margin-left:6px; color:#ef4444; font-size:1.1em; font-weight:900;">✕</span>`;
            
            btn.addEventListener("click", (e) => {
                e.preventDefault();
                e.stopPropagation();
                document.dispatchEvent(new CustomEvent("clearBono100Filtro"));
            });
            
            container.appendChild(btn);
        }
    };

    const initSearchFilters = () => {
        const openBtn = document.getElementById("open-filters-btn");
        const modal = document.getElementById("modal-filtros");
        const closeBtn = document.getElementById("close-modal-btn");
        const cancelBtn = document.getElementById("cancel-modal-btn");

        if (!modal) return;

        const toggleModal = (e?: Event) => {
            if (e) e.preventDefault();
            modal.classList.toggle("open");
            if (modal.classList.contains("open")) {
                document.body.style.overflow = "hidden";
            } else {
                document.body.style.overflow = "auto";
            }
        };

        openBtn?.addEventListener("click", toggleModal);
        closeBtn?.addEventListener("click", toggleModal);
        cancelBtn?.addEventListener("click", toggleModal);

        // Cerrar al hacer click fuera del modal
        modal.addEventListener("click", (e) => {
            if (e.target === modal) {
                toggleModal();
            }
        });

        // Cerrar con Escape
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && modal.classList.contains("open")) {
                toggleModal();
            }
        });

        // Escuchar cambios de filtros para actualizar chips
        document.addEventListener("filtersUpdated", (e) => {
            if (e && (e as any).detail) {
                updateActiveFilterChips((e as any).detail);
            }
        });
    };

    // Ejecutar en carga inicial y en cada transición de página
    document.addEventListener("astro:page-load", () => {
        initSearchFilters();

        // Carga inicial de chips desde la URL
        const iniciales = FiltroService.obtenerDeUrl();
        updateActiveFilterChips(iniciales);
    });
</script>

<style>
    .search-card {
        background: white;
        padding: 25px;
        border-radius: var(--radio-lg);
        box-shadow: var(--sombra-suave);
        margin-bottom: 25px;
    }

    .search-header {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 20px;
    }

    .search-icon-container {
        width: 40px;
        height: 40px;
        background: var(--color-primario);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }

    .search-info h3 {
        font-size: 1rem;
        font-weight: 600;
    }
    .search-info p {
        font-size: 0.8rem;
        color: var(--color-texto-grey);
    }

    .search-actions {
        margin-left: auto;
        display: flex;
        gap: 8px;
    }
    .icon-btn {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        border: none;
        background: var(--color-fondo-soft);
        color: var(--color-texto-grey);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }
    .icon-btn:hover {
        background: #eef2f3;
        color: var(--color-texto-dark);
    }

    .input-wrapper {
        position: relative;
        margin-bottom: 20px;
    }

    .input-icon {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--color-texto-grey);
    }

    .input-premium {
        width: 100%;
        padding: 14px 15px 14px 45px;
        border-radius: 14px;
        border: 2px solid transparent;
        background: var(--color-fondo-soft);
        font-size: 0.95rem;
        transition: all 0.25s ease;
    }

    .input-premium:focus {
        background: white;
        border-color: var(--color-primario);
        box-shadow: 0px 5px 20px 0px rgba(var(--vs-primary-raw), 0.15);
        outline: none;
        transform: translateY(-2px);
    }

    .search-filters {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .filter-label {
        font-size: 0.8rem;
        color: var(--color-texto-grey);
        font-weight: 500;
    }

    /* Estilos globales para los chips inyectados por JS */
    :global(.filter-mini-btn) {
        padding: 6px 14px;
        border-radius: 12px;
        border: 1px solid rgba(0, 0, 0, 0.05);
        background: var(--color-fondo-soft);
        font-size: 0.8rem;
        color: var(--color-texto-dark);
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.02);
    }

    :global(.filter-mini-btn:hover) {
        background: white;
        transform: translateY(-2px);
        box-shadow: var(--sombra-suave);
        border-color: var(--color-primario);
        color: var(--color-primario);
    }

    :global(.filter-mini-btn svg) {
        opacity: 0.7;
    }

    :global(.filter-mini-btn:hover svg) {
        opacity: 1;
        color: var(--color-primario);
    }

    .config-btn {
        width: 100%;
        padding: 12px;
        background: var(--color-primario);
        color: white;
        border: none;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        font-weight: 600;
        cursor: pointer;
        box-shadow: var(--sombra-primaria);
        transition: all 0.3s;
    }

    .config-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0px 10px 20px -5px rgba(var(--vs-primary-raw), 0.5);
    }
</style>
