---
interface Year {
    year: number;
    value: string;
    color: string;
    active?: boolean;
}

interface Props {
    years: Year[];
}

const { years } = Astro.props;
---

<div class="years-summary">
    {
        years.map((y) => (
            <div class={`year-item ${y.active ? "active" : ""}`}>
                {y.active && <div class="active-badge">ACTUAL</div>}
                <span class="y-val" style={`color: ${y.color}`}>
                    {y.value}
                </span>
                <span class="y-name">{y.year}</span>
            </div>
        ))
    }
</div>

<style is:global>
    .years-summary {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 15px;
        margin-bottom: 25px;
        margin-top: 10px;
    }
    .year-item {
        background: #f8fafc;
        padding: 20px 15px;
        border-radius: 20px;
        text-align: center;
        display: flex !important;
        flex-direction: column !important;
        align-items: center;
        justify-content: center;
        gap: 6px;
        position: relative;
        border: 2px solid transparent;
        transition: all 0.3s ease;
    }
    .year-item.active {
        background: white;
        border-color: #e8f7ea;
        box-shadow: 0 10px 25px rgba(76, 194, 83, 0.12);
        transform: translateY(-2px);
    }
    .active-badge {
        position: absolute;
        top: 0;
        left: 50%;
        transform: translateX(-50%) translateY(-50%);
        background: #4cc253;
        color: white;
        font-size: 0.6rem;
        font-weight: 900;
        padding: 4px 12px;
        border-radius: 20px;
        letter-spacing: 1px;
        white-space: nowrap;
        box-shadow: 0 4px 10px rgba(76, 194, 83, 0.3);
    }
    .y-val {
        font-size: 1.25rem;
        font-weight: 900;
        display: block;
        line-height: 1;
    }
    .y-name {
        font-size: 0.8rem;
        font-weight: 700;
        color: #64748b;
        letter-spacing: 0.5px;
    }

    @media (max-width: 640px) {
        .years-summary {
            grid-template-columns: repeat(2, 1fr);
        }
        .year-item:last-child {
            grid-column: span 2;
        }
    }
</style>
