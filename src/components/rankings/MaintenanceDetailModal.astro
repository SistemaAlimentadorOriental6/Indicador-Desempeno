---
import Icon from "../ui/Icon.astro";
---

<div id="maintenance-detail-modal" class="modal-overlay">
    <div class="modal-content large">
        <!-- HEADER REDISEÑADO -->
        <header class="modal-header">
            <div class="header-main">
                <div class="operator-profile">
                    <div class="profile-img-container">
                        <img
                            src=""
                            alt="Cargando..."
                            class="profile-img"
                            id="m-modal-img"
                        />
                    </div>
                    <div class="profile-info">
                        <div class="name-badge">
                            <h1 id="m-modal-nombre">---</h1>
                            <span class="role-tag" id="m-modal-rol-label"
                                >TÉCNICO</span
                            >
                        </div>
                        <div class="details-grid">
                            <!-- Grupo 1: Personal -->
                            <div class="detail-group">
                                <div class="detail-item">
                                    <Icon name="id-card" size={14} />
                                    <span
                                        >Cédula: <strong id="m-modal-cedula-val"
                                            >---</strong
                                        ></span
                                    >
                                </div>
                                <div class="detail-item">
                                    <Icon name="users" size={14} />
                                    <span
                                        >Edad: <strong id="m-modal-edad-val"
                                            >---</strong
                                        ></span
                                    >
                                </div>
                            </div>

                            <!-- Grupo 2: Empresa -->
                            <div class="detail-group">
                                <div class="detail-item">
                                    <Icon name="medal" size={14} />
                                    <span
                                        >Cargo: <strong id="m-modal-rol-val"
                                            >---</strong
                                        ></span
                                    >
                                </div>
                                <div class="detail-item">
                                    <Icon name="activity" size={14} />
                                    <span
                                        >Estado: <strong
                                            id="m-modal-estado-val"
                                            class="text-success">Activo</strong
                                        ></span
                                    >
                                </div>
                            </div>

                            <!-- Grupo 3: Estado -->
                            <div class="detail-group">
                                <div class="detail-item">
                                    <Icon name="calendar" size={14} />
                                    <span
                                        >Ingreso: <strong
                                            id="m-modal-ingreso-val">---</strong
                                        ></span
                                    >
                                </div>
                                <div class="detail-item">
                                    <Icon name="clock" size={14} />
                                    <span
                                        >Antigüedad: <strong
                                            id="m-modal-antiguedad-val"
                                            >---</strong
                                        ></span
                                    >
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="quick-stats">
                    <div class="stat-box dark">
                        <div class="stat-main">
                            <span class="value" id="m-modal-eff-periodo"
                                >---</span
                            >
                            <span class="label">Eficiencia Periodo</span>
                        </div>
                        <div class="status-indicator">
                            <Icon name="activity" size={14} />
                            <span id="m-modal-eff-status">Bueno</span>
                        </div>
                    </div>
                    <div class="stat-box success">
                        <div class="stat-main">
                            <span class="value" id="m-modal-cumplimiento-val"
                                >---</span
                            >
                            <span class="label">Cumplimiento</span>
                        </div>
                        <div class="status-indicator">
                            <Icon name="medal" size={14} />
                            <span id="m-modal-rango-val">ORO</span>
                        </div>
                    </div>
                    <button
                        class="close-modal-btn"
                        id="close-m-modal"
                        aria-label="Cerrar modal"
                    >
                        <Icon name="x" size={20} />
                    </button>
                </div>
            </div>

            <nav class="modal-nav">
                <button class="nav-btn active" data-tab="general">
                    <Icon name="activity" size={16} />
                    Vista General
                </button>
                <button class="nav-btn" data-tab="detalles">
                    <Icon name="activity" size={16} />
                    Detalles Actividad
                </button>
            </nav>
        </header>

        <div class="modal-body custom-scrollbar">
            <!-- PESTAÑA VISTA GENERAL -->
            <div id="m-tab-general" class="tab-content active">
                <section class="body-section">
                    <div class="section-header">
                        <Icon
                            name="activity"
                            size={20}
                            color="var(--color-primario)"
                        />
                        <h2>Indicadores Clave de Rendimiento</h2>
                    </div>
                    <div class="kpi-grid">
                        <div class="kpi-card success-light">
                            <div class="kpi-icon-wrapper">
                                <Icon name="clock" size={24} />
                            </div>
                            <div class="kpi-info">
                                <span
                                    class="kpi-value"
                                    id="m-modal-horas-prog-kpi">---</span
                                >
                                <span class="kpi-label">Horas Programadas</span>
                            </div>
                        </div>
                        <div class="kpi-card primary-light">
                            <div class="kpi-icon-wrapper">
                                <Icon name="activity" size={24} />
                            </div>
                            <div class="kpi-info">
                                <span
                                    class="kpi-value"
                                    id="m-modal-horas-real-kpi">---</span
                                >
                                <span class="kpi-label">Horas Realizadas</span>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="body-section">
                    <div class="section-header">
                        <Icon
                            name="trending-up"
                            size={20}
                            color="var(--color-primario)"
                        />
                        <h2>Comparativa de Horas por Quincena</h2>
                    </div>
                    <div class="chart-box-premium">
                        <div class="chart-container">
                            <canvas id="mPerformanceChart"></canvas>
                        </div>
                    </div>
                </section>
            </div>

            <!-- PESTAÑA DETALLES -->
            <div id="m-tab-detalles" class="tab-content">
                <div class="details-tables-grid">
                    <!-- SECCIÓN REALIZADO -->
                    <div class="table-section realization-card">
                        <div class="section-header-premium">
                            <h3>Horas Realizadas</h3>
                        </div>
                        <div class="table-scroll-area">
                            <div id="realizado-list" class="timeline-container">
                            </div>
                        </div>
                    </div>

                    <!-- SECCIÓN PROGRAMADO -->
                    <div class="table-section programming-card">
                        <div class="section-header-premium">
                            <h3>Horas Programadas</h3>
                        </div>
                        <div class="table-scroll-area">
                            <table class="premium-table">
                                <thead>
                                    <tr>
                                        <th>Fecha</th>
                                        <th>Horario</th>
                                        <th style="text-align: right">Total</th>
                                    </tr>
                                </thead>
                                <tbody id="m-modal-programado-body"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal para Previsualizar Imagen -->
<div id="image-preview-modal" class="image-preview-overlay">
    <div class="preview-container">
        <img src="" id="preview-img-full" alt="Vista previa del operario" />
        <button
            id="close-preview"
            class="close-preview-btn"
            aria-label="Cerrar vista previa"
        >
            <Icon name="x" size={24} />
        </button>
    </div>
</div>

<style is:global>
    /* MODAL BASE */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.7);
        backdrop-filter: blur(10px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        opacity: 0;
        visibility: hidden;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        padding: 20px;
    }

    /* IMAGE PREVIEW MODAL STYLES */
    .image-preview-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.9);
        backdrop-filter: blur(15px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 2100; /* Por encima del modal principal */
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: zoom-out;
    }

    .image-preview-overlay.active {
        opacity: 1;
        visibility: visible;
    }

    .preview-container {
        position: relative;
        max-width: 90%;
        max-height: 90%;
        transform: scale(0.95);
        transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        cursor: default;
    }

    .image-preview-overlay.active .preview-container {
        transform: scale(1);
    }

    .preview-container img {
        display: block;
        width: auto;
        height: auto;
        max-width: 100%;
        max-height: 85vh;
        border-radius: 24px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        border: 4px solid white;
    }

    .close-preview-btn {
        position: absolute;
        top: -20px;
        right: -20px;
        background: white;
        border: none;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #0f172a;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        transition: all 0.2s ease;
        z-index: 2101;
    }

    .close-preview-btn:hover {
        transform: scale(1.1) rotate(90deg);
        background: var(--color-primario);
        color: white;
    }

    .profile-img {
        cursor: zoom-in;
    }

    .modal-overlay.open {
        opacity: 1;
        visibility: visible;
    }

    .modal-content.large {
        background: white;
        width: 100%;
        max-width: 1600px;
        height: 90vh;
        border-radius: 40px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transform: scale(0.95) translateY(30px);
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .modal-overlay.open .modal-content {
        transform: scale(1) translateY(0);
    }

    /* HEADER */
    .modal-header {
        padding: 40px 40px 0 40px;
        background: white;
        border-bottom: 1px solid #f1f5f9;
    }

    .header-main {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 40px;
    }

    .operator-profile {
        display: flex;
        gap: 30px;
        align-items: center;
    }

    .profile-img-container {
        width: 100px;
        height: 100px;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
        border: 4px solid white;
    }

    .profile-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .profile-info h1 {
        font-size: 1.8rem;
        font-weight: 900;
        color: #0f172a;
        margin-bottom: 5px;
        letter-spacing: -0.02em;
    }

    .role-tag {
        font-size: 0.8rem;
        font-weight: 800;
        color: #64748b;
        background: #f1f5f9;
        padding: 4px 12px;
        border-radius: 10px;
        text-transform: uppercase;
        display: inline-block;
        margin-bottom: 15px;
    }

    .details-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px 40px;
        margin-top: 15px;
        width: 100%;
    }

    .detail-group {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .detail-item {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 0.82rem;
        color: #64748b;
        transition: all 0.2s ease;
    }

    .detail-item :global(svg) {
        color: var(--color-primario);
        opacity: 0.7;
    }

    .detail-item strong {
        color: #1e293b;
        font-weight: 700;
        margin-left: auto;
    }

    /* QUICK STATS */
    .quick-stats {
        display: flex;
        gap: 20px;
        align-items: center;
    }

    .stat-box {
        padding: 20px 30px;
        border-radius: 24px;
        min-width: 180px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        position: relative;
    }

    .stat-box.dark {
        background: #1e293b;
        color: white;
    }

    .stat-box.success {
        background: #2ecc71;
        color: white;
    }

    .stat-box .value {
        font-size: 1.8rem;
        font-weight: 900;
        display: block;
        line-height: 1;
    }

    .stat-box .label {
        font-size: 0.75rem;
        font-weight: 600;
        opacity: 0.8;
    }

    .status-indicator {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.75rem;
        font-weight: 700;
        background: rgba(255, 255, 255, 0.2);
        padding: 4px 12px;
        border-radius: 20px;
        width: fit-content;
    }

    .close-modal-btn {
        background: #f1f5f9;
        border: none;
        width: 44px;
        height: 44px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #64748b;
        transition: all 0.2s;
        margin-left: 10px;
    }

    .close-modal-btn:hover {
        background: #ef4444;
        color: white;
        transform: rotate(90deg);
    }

    /* NAV */
    .modal-nav {
        display: flex;
        gap: 30px;
    }

    .nav-btn {
        background: none;
        border: none;
        padding: 15px 5px;
        font-family: inherit;
        font-size: 0.9rem;
        font-weight: 700;
        color: #94a3b8;
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
        position: relative;
        transition: all 0.2s;
    }

    .nav-btn:hover {
        color: #475569;
    }

    .nav-btn.active {
        color: var(--color-primario);
    }

    .nav-btn.active::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--color-primario);
        border-radius: 3px 3px 0 0;
    }

    /* BODY */
    .modal-body {
        padding: 40px;
        flex: 1;
        overflow-y: auto;
        background: #f8fafc;
    }

    .body-section {
        margin-bottom: 40px;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 25px;
    }

    .section-header h2 {
        font-size: 1.25rem;
        font-weight: 800;
        color: #1e293b;
        margin: 0;
    }

    /* KPI CARDS */
    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 25px;
    }

    .kpi-card {
        background: white;
        padding: 30px;
        border-radius: 32px;
        display: flex;
        align-items: center;
        gap: 20px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.02);
        border: 1px solid rgba(0, 0, 0, 0.03);
        transition: transform 0.2s;
    }

    .kpi-card:hover {
        transform: translateY(-3px);
    }

    .kpi-icon-wrapper {
        width: 60px;
        height: 60px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .success-light .kpi-icon-wrapper {
        background: #ecfdf5;
        color: #10b981;
    }
    .primary-light .kpi-icon-wrapper {
        background: #eff6ff;
        color: #3b82f6;
    }

    .kpi-value {
        display: block;
        font-size: 1.8rem;
        font-weight: 900;
        color: #0f172a;
        line-height: 1.2;
    }

    .kpi-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: #64748b;
    }

    /* CHART BOX */
    .chart-box-premium {
        background: white;
        padding: 30px;
        border-radius: 32px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.02);
        border: 1px solid rgba(0, 0, 0, 0.03);
    }

    .chart-container {
        height: 350px;
        width: 100%;
    }

    /* TABLES */
    .tab-content {
        display: none;
    }

    .tab-content.active {
        display: block;
        animation: fadeIn 0.4s ease-out;
    }

    .details-tables-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 30px;
        padding-top: 10px;
    }

    .table-section {
        background: white;
        border-radius: 32px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
        border: 1px solid rgba(0, 0, 0, 0.03);
        display: flex;
        flex-direction: column;
        height: 600px;
        transition: transform 0.3s ease;
    }

    .table-section:hover {
        transform: translateY(-5px);
    }

    .section-header-premium {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 25px;
    }

    .table-section h3 {
        font-size: 1.25rem;
        font-weight: 800;
        color: #0f172a;
        margin: 0;
    }

    .table-scroll-area {
        overflow-y: auto;
        flex: 1;
        padding-right: 10px;
        scrollbar-width: thin;
        scrollbar-color: #e2e8f0 transparent;
    }

    /* TIMELINE ESTILO (REALIZADO) - DISEÑO MINIMALISTA PREMIUM */
    .timeline-container {
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding: 4px;
    }

    .day-group-card {
        background: #ffffff;
        border-radius: 20px;
        border: 1.5px solid #f1f5f9;
        transition: all 0.25s ease;
        overflow: hidden;
    }

    .day-group-card:hover {
        border-color: #e2e8f0;
        background: #fafbfc;
    }

    .day-group-card.open {
        border-color: var(--color-primario);
        background: #ffffff;
        box-shadow: 0 10px 30px rgba(var(--vs-primary-raw), 0.05);
    }

    .day-header {
        padding: 20px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        background: transparent;
    }

    .day-title {
        display: flex;
        align-items: center;
        gap: 12px;
        color: var(--color-texto-dark);
        font-weight: 700;
        font-size: 1rem;
    }

    .chevron-icon {
        transition: transform 0.25s ease;
        color: var(--color-texto-grey);
        flex-shrink: 0;
    }

    .day-group-card.open .chevron-icon {
        transform: rotate(180deg);
        color: var(--color-primario);
    }

    .day-total-badge {
        background: var(--color-fondo-soft);
        color: var(--color-texto-dark);
        padding: 8px 18px;
        border-radius: 14px;
        font-size: 0.85rem;
        font-weight: 800;
        border: 1px solid #e2e8f0;
    }

    .day-details-panel {
        display: none;
        padding: 0 24px 24px 64px;
        position: relative;
        background: #ffffff;
    }

    .day-details-panel::before {
        content: "";
        position: absolute;
        left: 31px;
        top: 0;
        bottom: 24px;
        width: 1.5px;
        background: var(--color-primario);
        border-radius: 2px;
        opacity: 0.15;
    }

    .day-group-card.open .day-details-panel {
        display: block;
        animation: fadeIn 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .task-item-premium {
        display: grid;
        grid-template-columns: 1fr auto;
        align-items: center;
        padding: 18px 0;
        border-bottom: 1px solid #f1f5f9;
        position: relative;
        gap: 20px;
    }

    .task-item-premium::before {
        content: "";
        position: absolute;
        left: -37px;
        top: 50%;
        transform: translateY(-50%);
        width: 12px;
        height: 12px;
        background: white;
        border: 2px solid var(--color-primario);
        border-radius: 50%;
        z-index: 2;
    }

    .task-item-premium:last-child {
        border-bottom: none;
    }

    .task-left {
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-width: 0;
    }

    .task-label-main {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--color-texto-dark);
    }

    .task-time-wrapper {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--color-texto-grey);
    }

    .task-time-ref {
        font-size: 0.85rem;
        font-weight: 600;
    }

    .task-duration {
        font-weight: 800;
        color: var(--color-primario);
        font-size: 0.95rem;
        background: rgba(var(--vs-primary-raw), 0.1);
        padding: 8px 16px;
        border-radius: 12px;
        white-space: nowrap;
        min-width: 70px;
        text-align: center;
    }

    /* EMPTY STATES */
    .empty-state-premium {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 80px 40px;
        color: var(--color-texto-grey);
        background: var(--color-fondo-soft);
        border-radius: 24px;
        border: 2px dashed #e2e8f0;
        margin: 0;
    }

    .empty-state-premium p {
        font-size: 1rem;
        font-weight: 600;
        color: var(--color-texto-grey);
    }

    .table-empty-state {
        text-align: center;
        padding: 80px 0 !important;
        color: var(--color-texto-grey);
        font-size: 0.95rem;
        font-weight: 500;
    }

    /* TABLA PROGRAMADO - MINIMALISTA */
    .premium-table {
        width: 100%;
        border-collapse: collapse;
    }

    .premium-table th {
        text-align: left;
        padding: 16px 20px;
        font-size: 0.75rem;
        color: var(--color-texto-grey);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        border-bottom: 2px solid var(--color-fondo-soft);
    }

    .program-row {
        background: #ffffff;
        transition: all 0.2s ease;
    }

    .program-row:hover {
        background: var(--color-fondo-soft);
    }

    .program-row td {
        padding: 18px 20px;
        font-size: 0.9rem;
        color: var(--color-texto-dark);
        border-bottom: 1px solid #f8fafc;
        font-weight: 600;
    }

    .date-cell-content {
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 700;
        color: var(--color-texto-dark);
    }

    .date-cell-content svg {
        color: var(--color-primario);
        opacity: 0.6;
    }

    .schedule-badge {
        background: var(--color-fondo-soft);
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--color-texto-dark);
        display: inline-block;
        border: 1px solid #eef1f4;
    }

    .net-hours {
        color: var(--color-texto-dark);
        font-weight: 800;
        font-size: 1rem;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(8px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<script>
    import { Chart, registerables } from "chart.js";
    import { getApiUrl, API_CONFIG } from "@config/api";
    Chart.register(...registerables);

    /**
     * @typedef {Object} ActivityItem
     * @property {string} fecha
     * @property {number} horas
     */

    /**
     * @typedef {Object} ProgramItem
     * @property {string} fecha
     * @property {string} horario
     * @property {number} neto
     */

    /**
     * @typedef {Object} OperatorData
     * @property {string} cedula
     * @property {string} nombre
     * @property {string} cargo
     * @property {string} codigo
     * @property {string} zona
     * @property {string} padrino
     * @property {string} foto
     * @property {string} fechaIngreso
     * @property {string} fechaNacimiento
     */

    class MaintenanceModalManager {
        private chartInstance: Chart | null = null;
        private operatorsCache: OperatorData[] | null = null;
        private svgNS = "http://www.w3.org/2000/svg";

        constructor() {
            this.init();
        }

        private init() {
            const modal = document.getElementById("maintenance-detail-modal");
            const closeBtn = document.getElementById("close-m-modal");
            const triggers = document.querySelectorAll(
                ".maintenance-card-trigger",
            );

            if (!modal) return;

            // Vincular eventos iniciales
            triggers.forEach((t) =>
                t.addEventListener("click", (e) => this.handleOpenModal(e)),
            );
            closeBtn?.addEventListener("click", () => this.handleCloseModal());
            modal.addEventListener("click", (e) => {
                if (e.target === modal) this.handleCloseModal();
            });

            this.setupTabNavigation(modal);
            this.setupMutationObserver();
            this.setupImagePreview();
        }

        private setupImagePreview() {
            const img = document.getElementById(
                "m-modal-img",
            ) as HTMLImageElement;
            const previewModal = document.getElementById("image-preview-modal");
            const previewImg = document.getElementById(
                "preview-img-full",
            ) as HTMLImageElement;
            const closeBtn = document.getElementById("close-preview");

            if (!img || !previewModal || !previewImg || !closeBtn) return;

            img.addEventListener("click", () => {
                const src = img.src;
                // Evitamos abrir si es el placeholder en SVG
                if (src && !src.includes("data:image/svg+xml")) {
                    previewImg.src = src;
                    previewModal.classList.add("active");
                    document.body.style.overflow = "hidden";
                }
            });

            const closePreview = () => {
                previewModal.classList.remove("active");
                // Solo restauramos el scroll si el modal principal no está abierto
                // Pero como este está encima, mejor verificamos el modal base
                const mainModal = document.getElementById(
                    "maintenance-detail-modal",
                );
                if (!mainModal || !mainModal.classList.contains("open")) {
                    document.body.style.overflow = "auto";
                }
            };

            closeBtn.addEventListener("click", closePreview);
            previewModal.addEventListener("click", (e) => {
                if (e.target === previewModal) closePreview();
            });

            // Tecla ESC para cerrar
            document.addEventListener("keydown", (e) => {
                if (
                    e.key === "Escape" &&
                    previewModal.classList.contains("active")
                ) {
                    closePreview();
                }
            });
        }

        private setupTabNavigation(modal: HTMLElement) {
            const navBtns = modal.querySelectorAll(".nav-btn");
            navBtns.forEach((btn) => {
                btn.addEventListener("click", () => {
                    const btnEl = btn as HTMLElement;
                    navBtns.forEach((b) => b.classList.remove("active"));
                    btnEl.classList.add("active");

                    const target = btnEl.dataset.tab;
                    modal
                        .querySelectorAll(".tab-content")
                        .forEach((c) => c.classList.remove("active"));
                    const targetTab = document.getElementById(
                        `m-tab-${target}`,
                    );
                    if (targetTab) targetTab.classList.add("active");
                });
            });
        }

        private setupMutationObserver() {
            const grid = document.querySelector(".maintenance-grid");
            if (!grid) return;

            const observer = new MutationObserver(() => {
                const newTriggers = document.querySelectorAll(
                    ".maintenance-card-trigger:not([data-event-attached])",
                );
                newTriggers.forEach((t) => {
                    t.addEventListener("click", (e) => this.handleOpenModal(e));
                    t.setAttribute("data-event-attached", "true");
                });
            });
            observer.observe(grid, { childList: true });
        }

        private async fetchOperators(): Promise<OperatorData[]> {
            if (this.operatorsCache) return this.operatorsCache;
            try {
                const resp = await fetch(
                    getApiUrl(API_CONFIG.ENDPOINTS.OPERADORES.GET_ALL),
                );
                if (resp.ok) {
                    this.operatorsCache = await resp.json();
                    return this.operatorsCache || [];
                }
            } catch (e) {
                console.error("Error fetching operators:", e);
            }
            return [];
        }

        private formatHoursValue(decimal: string | number | undefined): string {
            const num = parseFloat(String(decimal || 0));
            if (isNaN(num)) return "0:00";
            const h = Math.floor(Math.abs(num));
            const m = Math.round((Math.abs(num) % 1) * 60);
            const sign = num < 0 ? "-" : "";
            return `${sign}${h}:${m.toString().padStart(2, "0")}`;
        }

        private async handleOpenModal(e: Event) {
            const card = e.currentTarget as HTMLElement;
            const data = card.dataset;
            if (!data) return;

            const cedula = data.cedula || "";

            this.populateBasicInfo(data);
            this.populateKPIs(data);

            if (cedula) {
                this.enrichFromAPI(cedula);
            }

            const realizado: ActivityItem[] = JSON.parse(
                data.detalleRealizado || "[]",
            );
            const programado: ProgramItem[] = JSON.parse(
                data.detalleProgramado || "[]",
            );

            this.renderTimeline(realizado);
            this.renderProgrammingTable(programado);
            this.initChart(realizado, programado);

            const modal = document.getElementById("maintenance-detail-modal");
            if (modal) {
                modal.classList.add("open");
                document.body.style.overflow = "hidden";
            }
        }

        private handleCloseModal() {
            const modal = document.getElementById("maintenance-detail-modal");
            if (modal) {
                modal.classList.remove("open");
                document.body.style.overflow = "auto";
            }
        }

        private populateBasicInfo(data: DOMStringMap) {
            const set = (id: string, val: string | undefined) => {
                const el = document.getElementById(id);
                if (el) el.textContent = val || "---";
            };

            set("m-modal-nombre", data.nombre);
            set("m-modal-rol-label", data.rol);
            set("m-modal-cedula-val", data.cedula);
            set("m-modal-codigo-val", data.codigo);
            set("m-modal-rol-val", data.rol);
            set("m-modal-zona-val", data.zona);
            set("m-modal-edad-val", data.edad);
            set("m-modal-antiguedad-val", data.antiguedad);
            set("m-modal-padrino-val", data.padrino);

            const ingEl = document.getElementById("m-modal-ingreso-val");
            if (ingEl && data.ingreso) {
                ingEl.textContent = data.ingreso.includes("T")
                    ? new Date(data.ingreso).toLocaleDateString()
                    : data.ingreso;
            }

            const imgEl = document.getElementById(
                "m-modal-img",
            ) as HTMLImageElement;
            if (imgEl) {
                imgEl.src = data.imagen || "";
                imgEl.alt = data.nombre || "Avatar";
            }

            const effVal = data.cumplimiento || "0%";
            set("m-modal-eff-periodo", effVal);
            set("m-modal-cumplimiento-val", effVal);
            set("m-modal-rango-val", data.rango);

            const effStatusEl = document.getElementById("m-modal-eff-status");
            if (effStatusEl) {
                const effNum = parseFloat(effVal);
                effStatusEl.textContent =
                    effNum >= 90 ? "Bueno" : effNum >= 75 ? "Regular" : "Bajo";
            }
        }

        private populateKPIs(data: DOMStringMap) {
            const hProgEl = document.getElementById("m-modal-horas-prog-kpi");
            if (hProgEl)
                hProgEl.textContent = this.formatHoursValue(
                    data.horasProgramadas,
                );

            const hRealEl = document.getElementById("m-modal-horas-real-kpi");
            if (hRealEl)
                hRealEl.textContent = this.formatHoursValue(
                    data.horasRealizadas,
                );
        }

        private async enrichFromAPI(cedula: string) {
            const ops = await this.fetchOperators();
            const operator = ops.find(
                (o) => String(o.cedula) === String(cedula),
            );
            if (!operator) return;

            const update = (id: string, val: string | undefined) => {
                const el = document.getElementById(id);
                if (el && val) el.textContent = val;
            };

            update("m-modal-nombre", operator.nombre);
            update("m-modal-rol-label", operator.cargo);
            update("m-modal-rol-val", operator.cargo);
            update("m-modal-codigo-val", operator.codigo);
            update("m-modal-zona-val", operator.zona);
            update("m-modal-padrino-val", operator.padrino);

            const imgEl = document.getElementById(
                "m-modal-img",
            ) as HTMLImageElement;
            if (imgEl) {
                imgEl.src = operator.foto || imgEl.src;
                imgEl.onerror = () => {
                    imgEl.src =
                        "data:image/svg+xml;charset=UTF-8,%3Csvg xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22 viewBox%3D%220 0 24 24%22 fill%3D%22%23cbd5e1%22%3E%3Cpath d%3D%22M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z%22%2F%3E%3C%2Fsvg%3E";
                };
            }

            if (operator.fechaIngreso) {
                const years = this.calculateYears(operator.fechaIngreso);
                update("m-modal-antiguedad-val", `${years} años`);
                update(
                    "m-modal-ingreso-val",
                    new Date(operator.fechaIngreso).toLocaleDateString(),
                );
            }

            if (operator.fechaNacimiento) {
                const age = this.calculateYears(operator.fechaNacimiento);
                update("m-modal-edad-val", `${age} años`);
            }
        }

        private calculateYears(dateString: string): number {
            const date = new Date(dateString);
            const now = new Date();
            let years = now.getFullYear() - date.getFullYear();
            const m = now.getMonth() - date.getMonth();
            if (m < 0 || (m === 0 && now.getDate() < date.getDate())) {
                years--;
            }
            return years;
        }

        private createIcon(
            pathData: string,
            size = 16,
            strokeWidth = 2,
        ): SVGElement {
            const svg = document.createElementNS(this.svgNS, "svg");
            svg.setAttribute("width", String(size));
            svg.setAttribute("height", String(size));
            svg.setAttribute("viewBox", "0 0 24 24");
            svg.setAttribute("fill", "none");
            svg.setAttribute("stroke", "currentColor");
            svg.setAttribute("stroke-width", String(strokeWidth));
            svg.setAttribute("stroke-linecap", "round");
            svg.setAttribute("stroke-linejoin", "round");

            const path = document.createElementNS(this.svgNS, "path");
            path.setAttribute("d", pathData);
            svg.appendChild(path);
            return svg;
        }

        private renderTimeline(realizado: ActivityItem[]) {
            const container = document.getElementById("realizado-list");
            if (!container) return;
            container.replaceChildren();

            if (realizado.length === 0) {
                this.renderEmptyState(
                    container,
                    "No hay actividades registradas",
                );
                return;
            }

            // Ordenar de más reciente a más antiguo
            const sortedRealizado = [...realizado].sort(
                (a, b) =>
                    new Date(b.fecha).getTime() - new Date(a.fecha).getTime(),
            );

            // Usar un Map para preservar el orden de inserción tras la ordenación
            const groupedMap = new Map();
            sortedRealizado.forEach((curr) => {
                const date = new Date(curr.fecha).toLocaleDateString();
                if (!groupedMap.has(date)) {
                    groupedMap.set(date, { total: 0, items: [] });
                }
                const group = groupedMap.get(date);
                group.total += parseFloat(String(curr.horas || 0));
                group.items.push(curr);
            });

            const fragment = document.createDocumentFragment();
            groupedMap.forEach((group, date) => {
                const card = document.createElement("div");
                card.className = "day-group-card";

                const header = document.createElement("div");
                header.className = "day-header";
                header.onclick = () => card.classList.toggle("open");

                const title = document.createElement("div");
                title.className = "day-title";

                const chevron = this.createIcon("M6 9l6 6 6-6", 20, 3);
                chevron.classList.add("chevron-icon");

                const dateTxt = document.createElement("span");
                dateTxt.textContent = date;

                title.append(chevron, dateTxt);

                const badge = document.createElement("span");
                badge.className = "day-total-badge";
                badge.textContent = this.formatHoursValue(group.total);

                header.append(title, badge);

                const panel = document.createElement("div");
                panel.className = "day-details-panel";

                group.items.forEach((item: ActivityItem) => {
                    const task = document.createElement("div");
                    task.className = "task-item-premium";

                    const left = document.createElement("div");
                    left.className = "task-left";

                    const label = document.createElement("span");
                    label.className = "task-label-main";
                    label.textContent = "Turno Registrado";

                    const timeWrap = document.createElement("div");
                    timeWrap.className = "task-time-wrapper";

                    const clock = document.createElementNS(this.svgNS, "svg");
                    clock.setAttribute("width", "14");
                    clock.setAttribute("height", "14");
                    clock.setAttribute("viewBox", "0 0 24 24");
                    clock.setAttribute("fill", "none");
                    clock.setAttribute("stroke", "currentColor");
                    clock.setAttribute("stroke-width", "2.5");

                    const circle = document.createElementNS(
                        this.svgNS,
                        "circle",
                    );
                    circle.setAttribute("cx", "12");
                    circle.setAttribute("cy", "12");
                    circle.setAttribute("r", "10");
                    const path = document.createElementNS(this.svgNS, "path");
                    path.setAttribute("d", "M12 6v6l4 2");
                    clock.append(circle, path);

                    const time = document.createElement("span");
                    time.className = "task-time-ref";
                    time.textContent = new Date(item.fecha).toLocaleTimeString(
                        [],
                        { hour: "2-digit", minute: "2-digit", hour12: true },
                    );

                    timeWrap.append(clock, time);
                    left.append(label, timeWrap);

                    const dur = document.createElement("span");
                    dur.className = "task-duration";
                    dur.textContent = this.formatHoursValue(item.horas);

                    task.append(left, dur);
                    panel.appendChild(task);
                });

                card.append(header, panel);
                fragment.appendChild(card);
            });
            container.appendChild(fragment);
        }

        private renderProgrammingTable(programado: ProgramItem[]) {
            const body = document.getElementById("m-modal-programado-body");
            if (!body) return;
            body.replaceChildren();

            if (programado.length === 0) {
                const tr = document.createElement("tr");
                const td = document.createElement("td");
                td.colSpan = 3;
                td.className = "table-empty-state";
                td.textContent = "Sin programación registrada";
                tr.appendChild(td);
                body.appendChild(tr);
                return;
            }

            const fragment = document.createDocumentFragment();
            // Ordenar de más reciente a más antiguo
            const sortedProgramado = [...programado].sort(
                (a, b) =>
                    new Date(b.fecha).getTime() - new Date(a.fecha).getTime(),
            );

            sortedProgramado.forEach((p) => {
                const tr = document.createElement("tr");
                tr.className = "program-row";

                // Fecha
                const tdDate = document.createElement("td");
                const dateWrap = document.createElement("div");
                dateWrap.className = "date-cell-content";

                const calIcon = this.createIcon(
                    "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z",
                    14,
                );
                const txt = document.createElement("span");
                txt.textContent = new Date(p.fecha).toLocaleDateString();

                dateWrap.append(calIcon, txt);
                tdDate.appendChild(dateWrap);

                // Horario
                const tdSchedule = document.createElement("td");
                const badge = document.createElement("span");
                badge.className = "schedule-badge";
                badge.textContent = p.horario;
                tdSchedule.appendChild(badge);

                // Total
                const tdTotal = document.createElement("td");
                const strong = document.createElement("span");
                strong.className = "net-hours";
                strong.textContent = this.formatHoursValue(p.neto);
                tdTotal.appendChild(strong);

                tr.append(tdDate, tdSchedule, tdTotal);
                fragment.appendChild(tr);
            });
            body.appendChild(fragment);
        }

        private renderEmptyState(container: HTMLElement, text: string) {
            const empty = document.createElement("div");
            empty.className = "empty-state-premium";

            const icon = this.createIcon(
                "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z",
                48,
                1.5,
            );
            icon.style.opacity = "0.3";
            icon.style.marginBottom = "15px";

            const p = document.createElement("p");
            p.textContent = text;

            empty.append(icon, p);
            container.appendChild(empty);
        }

        private initChart(realData: ActivityItem[], progData: ProgramItem[]) {
            const canvas = document.getElementById(
                "mPerformanceChart",
            ) as HTMLCanvasElement;
            if (!canvas) return;

            if (this.chartInstance) this.chartInstance.destroy();

            const allDates = [...realData, ...progData].map(
                (d) => new Date(d.fecha),
            );
            let startDay = 1,
                lastDay = 15,
                monthStr = String(new Date().getMonth() + 1).padStart(2, "0");

            if (allDates.length > 0) {
                const date = allDates[0];
                monthStr = String(date.getMonth() + 1).padStart(2, "0");
                if (date.getDate() > 15) {
                    startDay = 16;
                    lastDay = new Date(
                        date.getFullYear(),
                        date.getMonth() + 1,
                        0,
                    ).getDate();
                } else {
                    startDay = 1;
                    lastDay = 15;
                }
            }

            const numDays = lastDay - startDay + 1;
            const labels = Array.from(
                { length: numDays },
                (_, i) =>
                    String(startDay + i).padStart(2, "0") + "/" + monthStr,
            );
            const realPts = Array(numDays).fill(0);
            const progPts = Array(numDays).fill(0);

            for (let i = 0; i < numDays; i++) {
                const day = startDay + i;
                realData.forEach((r) => {
                    if (new Date(r.fecha).getDate() === day)
                        realPts[i] += parseFloat(String(r.horas || 0));
                });
                progData.forEach((p) => {
                    if (new Date(p.fecha).getDate() === day)
                        progPts[i] += parseFloat(String(p.neto || 0));
                });
            }

            this.chartInstance = new Chart(canvas, {
                type: "line",
                data: {
                    labels,
                    datasets: [
                        {
                            label: "Programadas",
                            data: progPts,
                            borderColor: "#3b82f6",
                            backgroundColor: "rgba(59, 130, 246, 0.05)",
                            fill: true,
                            tension: 0.4,
                        },
                        {
                            label: "Realizadas",
                            data: realPts,
                            borderColor: "#2ecc71",
                            backgroundColor: "rgba(46, 204, 113, 0.05)",
                            fill: true,
                            tension: 0.4,
                        },
                    ],
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true,
                            position: "top",
                            labels: { usePointStyle: true, padding: 20 },
                        },
                        tooltip: {
                            mode: "index",
                            intersect: false,
                            callbacks: {
                                label: (ctx) => {
                                    let l = ctx.dataset.label || "";
                                    if (l) l += ": ";
                                    if (ctx.parsed.y !== null)
                                        l += this.formatHoursValue(
                                            ctx.parsed.y,
                                        );
                                    return l;
                                },
                            },
                        },
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: "rgba(0,0,0,0.05)" },
                        },
                        x: { grid: { display: false } },
                    },
                },
            });
        }
    }

    // Inicialización
    document.addEventListener(
        "astro:page-load",
        () => new MaintenanceModalManager(),
    );
    setupMaintenanceModal(); // Fallback

    function setupMaintenanceModal() {
        if (!window.hasOwnProperty("__maintenanceModalInitialized")) {
            new MaintenanceModalManager();
            (window as any).__maintenanceModalInitialized = true;
        }
    }
</script>
